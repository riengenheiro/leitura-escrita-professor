---
import '../styles/global.css';
import { PRICE_BASIC, formatPrice } from '../config/pricing';
import { FACEBOOK_PIXEL_ID } from '../config/facebookPixel';

const title = `Leitura e Escrita para Professoras | Aula + 40 Modelos Práticos - R$ ${formatPrice(PRICE_BASIC, true)}`;
const description = `Cansada de improvisar na hora de observar, registrar e encaminhar? Mais de 3.300 professoras já usam os materiais da Dra. Guaciara Fornaciari. Acesse a aula + 40 modelos prontos por R$ ${PRICE_BASIC}!`;

const ogImage = 'https://leitura-escrita-professor.doutoraescola.com.br/images/leitura-escrita/og-leitura-escrita.webp';
---
<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <script is:inline define:vars={{ FACEBOOK_PIXEL_ID }}>
      !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', FACEBOOK_PIXEL_ID);
      fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none" alt="" src={"https://www.facebook.com/tr?id=" + FACEBOOK_PIXEL_ID + "&ev=PageView&noscript=1"} /></noscript>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/images/leitura-escrita/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/images/leitura-escrita/favicon.svg" />
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content="leitura, escrita, professoras, observação, sondagem, relatórios, adaptações curriculares, PAEE, encaminhamento, Dra. Guaciara Fornaciari, Doutora Escola" />
    <meta name="author" content="Dra. Guaciara Fornaciari - Doutora Escola" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#1C8C4D" />
    <link rel="canonical" href="https://leitura-escrita-professor.doutoraescola.com.br/" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://leitura-escrita-professor.doutoraescola.com.br/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/webp" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Doutora Escola" />
    <meta property="og:locale" content="pt_BR" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://connect.facebook.net" crossorigin />
    <link rel="dns-prefetch" href="https://www.facebook.com" />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" /></noscript>
  </head>
  <body>
    <slot />
    <script is:inline data-cfasync="false">
      (function () {
        var ALLOWED = ['aff', 'utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term', 'src', 'ref'];
        var HOST_MATCH = /(^|\.)((leitura-escrita-professor\.doutoraescola\.com\.br)|(fm\.doutoraescola\.com\.br)|(pay\.kiwify\.com(\.br)?)|(voomp\.com\.br))$/;

        function appendLandingParamsToUrl(targetUrl) {
          if (!targetUrl) return targetUrl;
          try {
            var landingParams = new URL(window.location.href).searchParams;
            var out = new URL(targetUrl, window.location.origin);
            landingParams.forEach(function (value, key) {
              if (ALLOWED.indexOf(key) === -1) return;
              if (!out.searchParams.has(key)) out.searchParams.set(key, value);
            });
            return out.href;
          } catch (e) { return targetUrl; }
        }

        document.addEventListener('click', function (event) {
          var target = event.target;
          if (!(target instanceof Element)) return;
          var link = target.closest('a[href]');
          if (!link) return;
          var href = link.getAttribute('href');
          if (!href || href === '#' || href.indexOf('javascript:') === 0) return;
          try {
            var parsed = new URL(href, window.location.origin);
            if (!HOST_MATCH.test(parsed.hostname)) return;
            link.setAttribute('href', appendLandingParamsToUrl(parsed.href));
          } catch (e) {}
        }, true);
      })();
    </script>
  </body>
</html>
