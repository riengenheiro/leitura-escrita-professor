PORT=3001
FRONTEND_URL=https://protocolo.vivasuamissao.top
NODE_ENV=production

# ============================================
# CONFIGURAÇÃO DE EMAIL
# ============================================
# Escolha UM dos métodos abaixo:

# OPÇÃO 1: SMTP (Recomendado - usa email da hospedagem)
SMTP_HOST=mail.vivasuamissao.top
SMTP_PORT=465
SMTP_USER=suporte@vivasuamissao.top
SMTP_PASS=sua_senha_aqui
EMAIL_FROM=Manual <suporte@vivasuamissao.top>

# OPÇÃO 2: Resend (alternativa)
# RESEND_API_KEY=re_xxxxxxxxxxxxx
# EMAIL_FROM=Manual <noreply@seudominio.com>

# ============================================
# WEBHOOK KIWIFY
# ============================================
# Token de segurança do webhook Kiwify (opcional)
# Se a Kiwify enviar token no header, configure aqui
# KIWIFY_WEBHOOK_TOKEN=seu_token_secreto_aqui

# ============================================
# FACEBOOK PIXEL (opcional)
# ============================================
# Você pode configurar um pixel padrão aqui ou
# enviar pixel_id e access_token na requisição da API

# Pixel ID (encontrado no Facebook Business Manager)
FACEBOOK_PIXEL_ID=123456789

# Access Token (gerado nas configurações da API de Conversões)
# Como obter: https://business.facebook.com > Pixels > API de Conversões
FACEBOOK_ACCESS_TOKEN=seu_access_token_aqui

# Test Event Code (opcional - para testes)
# Usado para testar eventos sem afetar dados de produção
FACEBOOK_TEST_EVENT_CODE=TEST12345

# Debug Mode (true/false)
# Ativa logs detalhados dos eventos do Facebook Pixel
FACEBOOK_DEBUG=false
