---
import '../styles/global.css';
import AffiliateCheckoutLinks from '../components/AffiliateCheckoutLinks.astro';
import ConversionTracker from '../components/ConversionTracker.astro';

// URL do site — TESTE: http://codigos.vivasuamissao.top/ | PROD: https://codigos.doutoraescola.com.br/
const SITE_URL = 'http://codigos.vivasuamissao.top';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Doutora Escola | Guia Completo dos Códigos Alfanuméricos da BNCC - R$ 10,00', description = 'Aprenda de uma vez por todas como usar os Códigos da BNCC de forma simples, prática e sem enrolação! Este guia completo explica cada detalhe dos códigos alfanuméricos, com exemplos reais. Por apenas R$ 10,00!' } = Astro.props;

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Guia Completo dos Códigos Alfanuméricos da BNCC',
  description: 'Aprenda de uma vez por todas como usar os Códigos da BNCC de forma simples, prática e sem enrolação! Este guia completo explica cada detalhe dos códigos alfanuméricos, com exemplos reais.',
  image: `${SITE_URL}/images/doutora-escola/01-hero.png`,
  brand: { '@type': 'Organization', name: 'Doutora Escola', description: 'G&R Instituto Educacional - Especialistas em Educação' },
  offers: {
    '@type': 'Offer',
    url: `${SITE_URL}/`,
    priceCurrency: 'BRL',
    price: '10.00',
    priceValidUntil: '2026-12-31',
    availability: 'https://schema.org/InStock',
    seller: { '@type': 'Organization', name: 'Doutora Escola' },
  },
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: '2000' },
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Doutora Escola - Guia Completo dos Códigos Alfanuméricos da BNCC',
  description: 'Guia completo e prático para entender e usar os códigos alfanuméricos da BNCC',
  url: `${SITE_URL}/`,
  author: { '@type': 'Person', name: 'Dra. Guaciara Fornaciari', jobTitle: 'Fonoaudióloga e Especialista em Educação' },
};
---
<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favico.png" />
    <link rel="apple-touch-icon" href="/favico.png" />
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content="BNCC, códigos alfanuméricos, códigos BNCC, educação infantil, ensino fundamental, planejamento escolar, documentação pedagógica, Dra. Guaciara Fornaciari, Doutora Escola" />
    <meta name="author" content="Dra. Guaciara Fornaciari - Doutora Escola" />
    <meta name="robots" content="index, follow" />
    <meta name="language" content="Portuguese" />
    <meta name="revisit-after" content="7 days" />
    <link rel="canonical" href={`${SITE_URL}/`} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${SITE_URL}/`} />
    <meta property="og:title" content="Guia Completo dos Códigos Alfanuméricos da BNCC - R$ 10,00" />
    <meta property="og:description" content="Aprenda de uma vez por todas como usar os Códigos da BNCC de forma simples, prática e sem enrolação! Este guia completo explica cada detalhe dos códigos alfanuméricos, com exemplos reais." />
    <meta property="og:image" content={`${SITE_URL}/images/doutora-escola/01-hero.png`} />
    <meta property="og:image:secure_url" content={`${SITE_URL}/images/doutora-escola/01-hero.png`} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Guia Completo dos Códigos Alfanuméricos da BNCC - Doutora Escola" />
    <meta property="og:site_name" content="Doutora Escola" />
    <meta property="og:locale" content="pt_BR" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={`${SITE_URL}/`} />
    <meta name="twitter:title" content="Guia Completo dos Códigos Alfanuméricos da BNCC - R$ 10,00" />
    <meta name="twitter:description" content="Aprenda de uma vez por todas como usar os Códigos da BNCC de forma simples, prática e sem enrolação! Este guia completo explica cada detalhe dos códigos alfanuméricos." />
    <meta name="twitter:image" content={`${SITE_URL}/images/doutora-escola/01-hero.png`} />
    <meta name="twitter:image:alt" content="Guia Completo dos Códigos Alfanuméricos da BNCC - Doutora Escola" />
    <meta name="theme-color" content="#10b981" />
    <meta name="msapplication-TileColor" content="#10b981" />
    <meta name="format-detection" content="telephone=no" />
    <script is:inline>
      (function(f,b,e,v,n,t,s){
        if(f.fbq)return;
        n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};
        if(!f._fbq)f._fbq=n;
        n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];
      })(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');
    </script>
    <script type="text/javascript" is:inline>
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "vr1hrzuj48");
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://connect.facebook.net" crossorigin />
    <link rel="dns-prefetch" href="https://www.facebook.com" />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" />
    </noscript>
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
  </head>
  <body>
    <slot />
    <AffiliateCheckoutLinks />
    <ConversionTracker />
    <script is:inline data-cfasync="false">
      (function () {
        var ALLOWED = ['aff', 'utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term', 'src', 'ref'];
        var HOST_MATCH = /(^|\.)((fm\.doutoraescola\.com\.br)|(pay\.kiwify\.com(\.br)?)|(voomp\.com\.br))$/;

        function appendLandingParamsToUrl(targetUrl) {
          if (!targetUrl) return targetUrl;
          var landingParams;
          var out;
          try {
            landingParams = new URL(window.location.href).searchParams;
            out = new URL(targetUrl, window.location.origin);
          } catch (e) {
            return targetUrl;
          }
          landingParams.forEach(function (value, key) {
            if (ALLOWED.indexOf(key) === -1) return;
            if (!out.searchParams.has(key)) out.searchParams.set(key, value);
          });
          return out.href;
        }

        document.addEventListener(
          'click',
          function (event) {
            var target = event.target;
            if (!(target instanceof Element)) return;
            var link = target.closest('a[href]');
            if (!link) return;

            var href = link.getAttribute('href');
            if (!href || href === '#' || href.indexOf('javascript:') === 0) return;

            var parsed;
            try {
              parsed = new URL(href, window.location.origin);
            } catch (e) {
              return;
            }
            if (!HOST_MATCH.test(parsed.hostname)) return;

            link.setAttribute('href', appendLandingParamsToUrl(parsed.href));
          },
          true
        );
      })();
    </script>
  </body>
</html>
