---
import { CHECKOUT_EMBED } from '../../config/checkoutEmbed';
const { url, allowedOrigin, defaultSuccessUrl } = CHECKOUT_EMBED;
---
<div
  id="checkout-modal"
  class="checkout-modal fixed inset-0 z-[9999] hidden"
  role="dialog"
  aria-modal="true"
  aria-labelledby="checkout-modal-title"
  data-checkout-url={url}
  data-allowed-origin={allowedOrigin}
  data-default-success-url={defaultSuccessUrl}
>
  <div class="checkout-modal-backdrop absolute inset-0 bg-black/60 backdrop-blur-sm" data-close-modal></div>

  <div class="checkout-modal-box absolute inset-4 md:inset-8 lg:inset-12 bg-white rounded-2xl shadow-2xl flex flex-col overflow-hidden">
    <header class="flex items-center justify-between gap-3 px-4 py-3 bg-gray-100 border-b border-gray-200 flex-shrink-0">
      <span id="checkout-modal-title" class="font-semibold text-gray-800">Finalizar compra</span>
      <div class="flex items-center gap-3">
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-green-600 hover:text-green-700 font-medium underline"
        >
          Abrir em nova aba
        </a>
        <button
          type="button"
          class="checkout-modal-close w-10 h-10 flex items-center justify-center rounded-full bg-gray-200 hover:bg-gray-300 text-gray-700 transition-colors"
          aria-label="Fechar"
          data-close-modal
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </header>

    <div class="flex-1 min-h-0 relative">
      <iframe
        id="checkout-iframe"
        title="Checkout"
        class="absolute inset-0 w-full h-full border-0"
        allow="payment"
      ></iframe>
    </div>
  </div>
</div>

<script>
  (function () {
    const modal = document.getElementById('checkout-modal');
    if (!modal) return;

    const checkoutUrl = modal.getAttribute('data-checkout-url') || '';
    const allowedOrigin = modal.getAttribute('data-allowed-origin') || '';
    const defaultSuccessUrl = modal.getAttribute('data-default-success-url') || '/obrigado';
    const iframe = document.getElementById('checkout-iframe');

    function isSafari() {
      const ua = navigator.userAgent;
      return (ua.includes('Safari') && !ua.includes('Chrome')) || /iPhone|iPad|iPod/.test(ua);
    }

    function openModal() {
      if (!iframe || !checkoutUrl) return;
      iframe.src = checkoutUrl;
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.classList.add('hidden');
      document.body.style.overflow = '';
      if (iframe) iframe.src = 'about:blank';
    }

    document.querySelectorAll('.js-open-checkout-modal').forEach(function (el) {
      el.addEventListener('click', function (e) {
        e.preventDefault();
        if (isSafari()) {
          window.open(checkoutUrl, '_blank', 'noopener,noreferrer');
          return;
        }
        openModal();
      });
    });

    modal.querySelectorAll('[data-close-modal]').forEach(function (el) {
      el.addEventListener('click', closeModal);
    });

    modal.addEventListener('click', function (e) {
      if (e.target.classList.contains('checkout-modal-backdrop')) closeModal();
    });

    window.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
    });

    window.addEventListener('message', function (event) {
      if (event.origin !== allowedOrigin) return;
      const data = event.data;
      if (data && data.type === 'CHECKOUT_SUCCESS') {
        closeModal();
        window.location.href = typeof data.url === 'string' && data.url ? data.url : defaultSuccessUrl;
      }
    });
  })();
</script>
