---
import { CHECKOUT_EMBED } from '../../config/checkoutEmbed';
const { url, allowedOrigin, defaultSuccessUrl } = CHECKOUT_EMBED;
---
<div
  id="checkout-modal"
  class="checkout-modal fixed inset-0 z-[9999] hidden"
  role="dialog"
  aria-modal="true"
  aria-labelledby="checkout-modal-title"
  data-checkout-url={url}
  data-allowed-origin={allowedOrigin}
  data-default-success-url={defaultSuccessUrl}
>
  <div class="checkout-modal-backdrop absolute inset-0 bg-black/60 backdrop-blur-sm" data-close-modal></div>

  <div class="checkout-modal-box absolute inset-4 md:inset-8 lg:inset-12 bg-white rounded-2xl shadow-2xl flex flex-col overflow-hidden">
    <header class="flex items-center justify-between gap-3 px-4 py-3 bg-gray-100 border-b border-gray-200 flex-shrink-0">
      <span id="checkout-modal-title" class="font-semibold text-gray-800">Finalizar compra</span>
      <div class="flex items-center gap-3">
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-green-600 hover:text-green-700 font-medium underline"
        >
          Abrir em nova aba
        </a>
        <button
          type="button"
          class="checkout-modal-close w-10 h-10 flex items-center justify-center rounded-full bg-gray-200 hover:bg-gray-300 text-gray-700 transition-colors"
          aria-label="Fechar"
          data-close-modal
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </header>

    <div class="flex-1 min-h-0 relative">
      <div
        id="checkout-loading"
        class="absolute inset-0 z-10 flex flex-col items-center justify-center gap-3 bg-white text-gray-600"
        role="status"
        aria-live="polite"
      >
        <div class="w-7 h-7 rounded-full border-2 border-gray-300 border-t-green-600 animate-spin"></div>
        <p class="text-sm font-medium">Carregando checkout seguro...</p>
      </div>
      <div
        id="checkout-error"
        class="absolute inset-0 z-20 hidden flex flex-col items-center justify-center gap-3 bg-white px-6 text-center"
        role="alert"
      >
        <p class="text-base font-semibold text-gray-800">Nao foi possivel carregar o checkout.</p>
        <p class="text-sm text-gray-600">Tente novamente ou abra em uma nova aba.</p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <button
            id="checkout-retry"
            type="button"
            class="px-4 py-2 rounded-lg bg-gray-800 hover:bg-black text-white text-sm font-semibold transition-colors"
          >
            Tentar novamente
          </button>
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="px-4 py-2 rounded-lg bg-green-600 hover:bg-green-700 text-white text-sm font-semibold transition-colors"
          >
            Abrir em nova aba
          </a>
        </div>
      </div>
      <iframe
        id="checkout-iframe"
        title="Checkout"
        class="absolute inset-0 w-full h-full border-0 opacity-0 transition-opacity"
        allow="payment"
      ></iframe>
    </div>
  </div>
</div>

<script type="module">
  import { appendLandingParamsToUrl } from '@shared/affiliateCheckoutUrl';

  (function () {
    const modal = document.getElementById('checkout-modal');
    if (!modal) return;
    modal.setAttribute('aria-hidden', 'true');

    const rawCheckoutUrl = modal.getAttribute('data-checkout-url') || '';
    const checkoutUrl = appendLandingParamsToUrl(rawCheckoutUrl);
    const allowedOrigin = modal.getAttribute('data-allowed-origin') || '';
    const defaultSuccessUrl = modal.getAttribute('data-default-success-url') || '/obrigado';
    const iframe = document.getElementById('checkout-iframe');
    const loading = document.getElementById('checkout-loading');
    const errorBox = document.getElementById('checkout-error');
    const retryButton = document.getElementById('checkout-retry');
    const closeButtons = modal.querySelectorAll('[data-close-modal]');

    modal.querySelectorAll('a[href*="fm.doutoraescola.com.br"]').forEach(function (a) {
      a.setAttribute('href', checkoutUrl);
    });

    let preloaded = false;
    let iframeLoaded = false;
    let preloadTimeout = null;
    let lastFocusedElement = null;

    const focusableSelector =
      'a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])';

    function isSafari() {
      const ua = navigator.userAgent;
      return (ua.includes('Safari') && !ua.includes('Chrome')) || /iPhone|iPad|iPod/.test(ua);
    }

    function showLoading() {
      if (loading) loading.classList.remove('hidden');
      if (errorBox) errorBox.classList.add('hidden');
      if (iframe) iframe.classList.add('opacity-0');
    }

    function showIframe() {
      if (loading) loading.classList.add('hidden');
      if (errorBox) errorBox.classList.add('hidden');
      if (iframe) iframe.classList.remove('opacity-0');
    }

    function showError() {
      if (loading) loading.classList.add('hidden');
      if (errorBox) errorBox.classList.remove('hidden');
    }

    function clearPreloadTimeout() {
      if (preloadTimeout) {
        clearTimeout(preloadTimeout);
        preloadTimeout = null;
      }
    }

    function startPreloadTimeout() {
      clearPreloadTimeout();
      preloadTimeout = setTimeout(function () {
        if (!iframeLoaded) showError();
      }, 12000);
    }

    function getFocusableElements() {
      return modal.querySelectorAll(focusableSelector);
    }

    function trapFocus(e) {
      if (e.key !== 'Tab' || modal.classList.contains('hidden')) return;
      const focusableElements = getFocusableElements();
      if (!focusableElements.length) return;
      const first = focusableElements[0];
      const last = focusableElements[focusableElements.length - 1];

      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }

    function setModalOpenState() {
      modal.classList.remove('hidden');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      const firstCloseButton = closeButtons[0];
      if (firstCloseButton && typeof firstCloseButton.focus === 'function') {
        firstCloseButton.focus();
      }
    }

    /** Carrega o checkout no iframe em background (só uma vez). Ao clicar, já está carregado. */
    function preloadCheckout() {
      if (!iframe || !checkoutUrl || preloaded) return;
      preloaded = true;
      showLoading();
      startPreloadTimeout();
      iframe.src = checkoutUrl;
    }

    function openModal() {
      if (!iframe || !checkoutUrl) return;
      lastFocusedElement = document.activeElement;
      preloadCheckout();
      setModalOpenState();
    }

    function closeModal() {
      modal.classList.add('hidden');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      // Não limpa o iframe: ao reabrir o checkout já está carregado (melhor UX)
      if (lastFocusedElement && typeof lastFocusedElement.focus === 'function') {
        lastFocusedElement.focus();
      }
    }

    if (iframe) {
      iframe.addEventListener('load', function () {
        iframeLoaded = true;
        clearPreloadTimeout();
        showIframe();
      });
    }

    const openTriggers = document.querySelectorAll('.js-open-checkout-modal');
    openTriggers.forEach(function (el) {
      el.addEventListener('click', function (e) {
        e.preventDefault();
        if (isSafari()) {
          window.open(checkoutUrl, '_blank', 'noopener,noreferrer');
          return;
        }
        openModal();
      });
      // Preload ao passar o mouse no botão — quando clicar, já está carregado
      let hoverTimer;
      el.addEventListener('mouseenter', function () {
        hoverTimer = setTimeout(preloadCheckout, 300);
      });
      el.addEventListener('mouseleave', function () {
        clearTimeout(hoverTimer);
      });
      el.addEventListener(
        'touchstart',
        function () {
          preloadCheckout();
        },
        { passive: true, once: true }
      );
    });

    // Preload quando a seção de preços (#opcoes) entra na tela
    const pricingSection = document.getElementById('opcoes');
    if (pricingSection && typeof IntersectionObserver !== 'undefined') {
      const observer = new IntersectionObserver(
        function (entries) {
          if (entries[0].isIntersecting) {
            preloadCheckout();
            observer.disconnect();
          }
        },
        { rootMargin: '100px', threshold: 0.1 }
      );
      observer.observe(pricingSection);
    }

    closeButtons.forEach(function (el) {
      el.addEventListener('click', closeModal);
    });

    modal.addEventListener('click', function (e) {
      if (e.target.classList.contains('checkout-modal-backdrop')) closeModal();
    });

    window.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
      trapFocus(e);
    });

    if (retryButton) {
      retryButton.addEventListener('click', function () {
        if (!iframe || !checkoutUrl) return;
        iframeLoaded = false;
        showLoading();
        startPreloadTimeout();
        iframe.src = checkoutUrl;
      });
    }

    window.addEventListener('message', function (event) {
      if (event.origin !== allowedOrigin) return;
      if (iframe && event.source !== iframe.contentWindow) return;
      const data = event.data;
      if (data && data.type === 'CHECKOUT_SUCCESS') {
        closeModal();
        window.location.href = typeof data.url === 'string' && data.url ? data.url : defaultSuccessUrl;
      }
    });
  })();
</script>
