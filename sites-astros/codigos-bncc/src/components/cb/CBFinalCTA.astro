---
import FileText from '../icons/FileText.astro';
---
<section class="bg-gradient-to-b from-red-600 to-red-700 text-white py-12 md:py-16">
  <div class="max-w-3xl mx-auto px-6 text-center">
    <h2 class="text-2xl md:text-3xl lg:text-4xl font-extrabold mb-4">Não perca essa oportunidade!</h2>
    <p class="text-lg md:text-xl mb-6 opacity-95">
      Domine os códigos da BNCC de uma vez por todas
    </p>
    
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a
        href="#"
        class="js-open-checkout-modal inline-flex items-center gap-2 px-6 py-3 bg-white/20 hover:bg-white/30 text-white text-lg font-bold rounded-xl transition-all border-2 border-white/40"
      >
        Básico R$ 10
      </a>
      <a
        href="https://pay.voompcreators.com.br/8534/offer/KShiZL/?b_id_1=2497&b_offer_1=7AYnyF&b_id_2=1503&b_offer_2=NzZHqM&b_id_3=2058&b_offer_3=vtCUUI&ch_id=1806"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 bg-yellow-400 hover:bg-yellow-300 text-black text-xl font-extrabold rounded-xl transition-all transform hover:scale-105 shadow-2xl"
      >
        <FileText class="w-5 h-5" />
        COMPLETO R$ 29
      </a>
    </div>
    
    <p class="text-sm mt-5 opacity-80">
      ⚡ Acesso imediato • 🔒 Compra segura • ✅ Garantia 7 dias
    </p>
  </div>
</section>
