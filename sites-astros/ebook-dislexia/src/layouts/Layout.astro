---
import '../styles/global.css';
import { SITE_URL, FACEBOOK_PIXEL_ID } from '../config/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'As Letras Dançarinas — Ebook Gratuito | Doutora Escola',
  description = 'Ebook gratuito para professoras: "As Letras Dançarinas — Um Guia para uma Sala de Aula de Todos". Estratégias práticas para ajudar alunos com dislexia na sala de aula. Por Guaciara Fornaciari.',
} = Astro.props;

const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <script is:inline define:vars={{ FACEBOOK_PIXEL_ID }}>
      !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', FACEBOOK_PIXEL_ID);
      fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none" alt="" src={"https://www.facebook.com/tr?id=" + FACEBOOK_PIXEL_ID + "&ev=PageView&noscript=1"} /></noscript>
    <link rel="preconnect" href="https://connect.facebook.net" crossorigin />
    <link rel="dns-prefetch" href="https://www.facebook.com" />
    <link rel="preconnect" href="https://fm.doutoraescola.com.br" crossorigin />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={`${base}favicon.png`} />
    <link rel="apple-touch-icon" href={`${base}favicon.png`} />
    <link rel="canonical" href={SITE_URL + Astro.url.pathname} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="dislexia, educação inclusiva, professoras, ebook gratuito, sala de aula, As Letras Dançarinas, Doutora Escola" />
    <meta name="theme-color" content="#2C3E99" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={SITE_URL + Astro.url.pathname} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Doutora Escola" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:image" content={SITE_URL + '/images/og-image.webp'} />
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,600&display=swap" />
  </head>
  <body>
    <slot />
    <script is:inline data-cfasync="false">
      (function () {
        var ALLOWED = ['aff', 'utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term', 'src', 'ref'];
        var HOST_MATCH = /(^|\.)((fm\.doutoraescola\.com\.br)|(pay\.kiwify\.com(\.br)?)|(voomp\.com\.br))$/;

        function appendLandingParamsToUrl(targetUrl) {
          if (!targetUrl) return targetUrl;
          var landingParams;
          var out;
          try {
            landingParams = new URL(window.location.href).searchParams;
            out = new URL(targetUrl, window.location.origin);
          } catch (e) {
            return targetUrl;
          }
          landingParams.forEach(function (value, key) {
            if (ALLOWED.indexOf(key) === -1) return;
            if (!out.searchParams.has(key)) out.searchParams.set(key, value);
          });
          return out.href;
        }

        document.addEventListener(
          'click',
          function (event) {
            var target = event.target;
            if (!(target instanceof Element)) return;
            var link = target.closest('a[href]');
            if (!link) return;

            var href = link.getAttribute('href');
            if (!href || href === '#' || href.indexOf('javascript:') === 0) return;

            var parsed;
            try {
              parsed = new URL(href, window.location.origin);
            } catch (e) {
              return;
            }
            if (!HOST_MATCH.test(parsed.hostname)) return;

            link.setAttribute('href', appendLandingParamsToUrl(parsed.href));
          },
          true
        );
      })();
    </script>
  </body>
</html>
