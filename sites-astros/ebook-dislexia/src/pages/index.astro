---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import { CHECKOUT_EMBED, CHECKOUT_DIRECT, CHECKOUT_CONFIG } from '../config/site';

const base = import.meta.env.BASE_URL;
const img = (path: string) => `${base}${path.replace(/^\//, '')}`;
---
<Layout>
  <main class="min-h-screen w-full bg-white font-sans antialiased">

    <!-- ═══════════ HERO + FORMULÁRIO ═══════════ -->
    <section class="relative overflow-hidden bg-gradient-to-br from-[#EEF2FF] via-[#F0F4FF] to-white">
      <div class="absolute inset-0 opacity-20 pointer-events-none">
        <div class="absolute top-10 left-10 w-72 h-72 bg-primary/10 rounded-full blur-3xl"></div>
        <div class="absolute bottom-10 right-10 w-96 h-96 bg-secondary/10 rounded-full blur-3xl"></div>
      </div>

      <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-10 md:py-16">
        <div class="grid lg:grid-cols-2 gap-10 lg:gap-14 items-start">

          <!-- ESQUERDA: Mockup + pitch -->
          <div class="flex flex-col items-center lg:items-start text-center lg:text-left">
            <span class="inline-flex items-center gap-2 bg-secondary/10 text-secondary-dark font-semibold text-sm px-4 py-1.5 rounded-full mb-5">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              Ebook 100% Gratuito
            </span>

            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-primary-dark leading-[1.1] mb-2">
              As Letras Dançarinas
            </h1>
            <h2 class="text-lg sm:text-xl font-semibold text-gray-500 mb-6">
              Um Guia para uma Sala de Aula de Todos
            </h2>

            <div class="relative mx-auto lg:mx-0 mb-6">
              <div class="absolute -inset-3 bg-gradient-to-br from-primary/20 to-secondary/20 rounded-2xl blur-2xl"></div>
              <img
                src={img('images/mockup-ebook.webp')}
                alt="Ebook As Letras Dançarinas"
                class="relative w-48 sm:w-56 md:w-64 rounded-xl shadow-2xl"
                width="256"
                height="320"
                loading="eager"
              />
            </div>

            <div class="flex items-center gap-3 mb-4">
              <img
                src={img('images/guaciara-foto.webp')}
                alt="Guaciara Fornaciari"
                class="w-11 h-11 rounded-full object-cover border-2 border-white shadow"
                width="44"
                height="44"
                loading="eager"
              />
              <div class="text-left">
                <p class="font-bold text-gray-800 text-sm">Guaciara Fornaciari</p>
                <p class="text-xs text-gray-500">Especialista em inclusão · +25 anos na Educação</p>
              </div>
            </div>

            <ul class="space-y-2 text-left text-gray-700 text-sm sm:text-base mb-4">
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-secondary flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <span>O que é dislexia e como identificar os sinais</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-secondary flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <span>Estratégias práticas para usar na sala de aula</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-secondary flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <span>Avaliações inclusivas e reforço positivo</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-secondary flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <span>Escrito por quem já foi professora, coordenadora e diretora — linguagem de sala de aula</span>
              </li>
            </ul>

            <div class="flex flex-wrap items-center gap-3 text-xs text-gray-400">
              <span class="flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg>
                Dados seguros
              </span>
              <span>·</span>
              <span>Mais de 6.000 professoras confiam</span>
            </div>
          </div>

          <!-- DIREITA: Embed do checkout -->
          <div id="cadastro" class="bg-white rounded-2xl shadow-xl border border-gray-200 overflow-hidden">
            <div class="bg-gradient-to-r from-primary to-primary-dark px-5 py-3 text-center">
              <p class="text-white font-bold text-base sm:text-lg">Receba o ebook grátis no seu e-mail</p>
            </div>
            <iframe
              id="checkout-embed"
              src={CHECKOUT_EMBED}
              title="Cadastro para receber o ebook gratuito"
              class="w-full border-0"
              style="min-height: 712px;"
              allow="payment"
            ></iframe>
            <noscript>
              <div class="text-center p-4">
                <a href={CHECKOUT_DIRECT} class="text-primary underline font-semibold">
                  Clique aqui para se cadastrar
                </a>
              </div>
            </noscript>
          </div>

        </div>
      </div>
    </section>

    <Footer />

  </main>

  <script is:inline define:vars={{ allowedOrigin: CHECKOUT_CONFIG.allowedOrigin, successUrl: CHECKOUT_CONFIG.successUrl }}>
    window.addEventListener('message', function (event) {
      if (event.origin !== allowedOrigin) return;
      var data = event.data;
      if (data && data.type === 'CHECKOUT_SUCCESS') {
        window.location.href = (typeof data.url === 'string' && data.url) ? data.url : successUrl;
      }
    });
  </script>

  <script define:vars={{ embedUrl: CHECKOUT_EMBED, directUrl: CHECKOUT_DIRECT }}>
    import { appendLandingParamsToUrl } from '@shared/affiliateCheckoutUrl';
    const merged = appendLandingParamsToUrl(embedUrl);
    const iframe = document.getElementById('checkout-embed');
    if (iframe) iframe.src = merged;
  </script>
</Layout>
