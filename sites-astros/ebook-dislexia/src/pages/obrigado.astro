---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
const publicImg = (path: string) => `${base}${path.replace(/^\//, '')}`;
---
<Layout
  title="Ebook enviado! | As Letras Dançarinas — Doutora Escola"
  description="Seu ebook As Letras Dançarinas já está a caminho. Participe do grupo de professoras no WhatsApp."
>
  <main class="min-h-screen w-full font-sans antialiased bg-gradient-to-b from-[#f0fdf4] via-white to-[#EEF2FF]">

    <!-- ═══════════ CONFIRMAÇÃO ═══════════ -->
    <section class="pt-16 md:pt-24 pb-12">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
        <div class="inline-flex items-center justify-center w-20 h-20 bg-secondary/10 rounded-full mb-6">
          <svg class="w-10 h-10 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>

        <h1 class="text-3xl sm:text-4xl font-extrabold text-primary-dark mb-4">
          Seu ebook <em>"As Letras Dançarinas"</em> já está a caminho!
        </h1>

        <p class="text-gray-600 text-lg mb-3">
          Verifique seu e-mail nos próximos instantes. O guia chegará em formato PDF, pronto para leitura.
        </p>

        <div class="bg-amber-50 border border-amber-200 rounded-xl px-5 py-4 text-sm text-amber-800 inline-block">
          <p>
            <strong>Não encontrou?</strong> Verifique a aba "Promoções" ou a pasta de spam — e mova para a caixa principal para garantir o recebimento dos próximos conteúdos.
          </p>
        </div>
      </div>
    </section>

    <!-- ═══════════ TRANSIÇÃO ═══════════ -->
    <section class="pb-8">
      <div class="max-w-2xl mx-auto px-4 sm:px-6">
        <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent mb-10"></div>
        <div class="text-center text-gray-700 space-y-4">
          <p>
            No ebook, você vai acompanhar a jornada da professora Beatriz. Ela decidiu que nenhum aluno ficaria para trás — e foi buscar as estratégias certas para isso.
          </p>
          <p>
            Mas Beatriz não fez tudo sozinha. Ela mantinha uma rede de apoio: família, fonoaudiólogo, psicopedagogo, colegas de escola.
          </p>
          <p class="text-primary-dark font-bold text-xl">
            Eu quero oferecer essa rede para você também.
          </p>
        </div>
      </div>
    </section>

    <!-- ═══════════ CONVITE WHATSAPP ═══════════ -->
    <section class="py-12 md:py-16">
      <div class="max-w-2xl mx-auto px-4 sm:px-6">
        <div class="bg-white rounded-3xl shadow-xl border border-gray-100 p-8 md:p-10 text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-[#25D366]/10 rounded-full mb-6">
            <svg class="w-8 h-8 text-[#25D366]" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>

          <h2 class="text-2xl sm:text-3xl font-bold text-primary-dark mb-4">
            Participe do nosso grupo de professoras no WhatsApp
          </h2>

          <p class="text-gray-600 mb-6">
            Um espaço exclusivo onde professoras que enfrentam os mesmos desafios se encontram, trocam experiências e se fortalecem mutuamente.
          </p>

          <div class="grid sm:grid-cols-2 gap-3 mb-8 text-left">
            <div class="flex gap-3 items-start bg-surface rounded-xl p-4">
              <span class="text-secondary text-xl flex-shrink-0">📚</span>
              <p class="text-gray-700 text-sm">Orientações práticas sobre dislexia, inclusão e adaptações para a sala de aula</p>
            </div>
            <div class="flex gap-3 items-start bg-surface rounded-xl p-4">
              <span class="text-secondary text-xl flex-shrink-0">👩‍🏫</span>
              <p class="text-gray-700 text-sm">Professoras que vivem a mesma realidade e entendem seus desafios</p>
            </div>
            <div class="flex gap-3 items-start bg-surface rounded-xl p-4">
              <span class="text-secondary text-xl flex-shrink-0">🎁</span>
              <p class="text-gray-700 text-sm">Conteúdos e materiais compartilhados em primeira mão</p>
            </div>
            <div class="flex gap-3 items-start bg-surface rounded-xl p-4">
              <span class="text-secondary text-xl flex-shrink-0">💬</span>
              <p class="text-gray-700 text-sm">Espaço seguro para perguntar e aprender sem julgamento</p>
            </div>
          </div>

          <p class="text-sm text-gray-500 mb-6">A participação é gratuita.</p>

          <a
            href="#"
            class="inline-flex items-center gap-3 bg-[#25D366] hover:bg-[#1ebe5a] text-white font-bold text-lg px-8 py-4 rounded-xl shadow-[0_8px_30px_rgba(37,211,102,0.35)] hover:shadow-[0_12px_40px_rgba(37,211,102,0.45)] hover:scale-[1.02] active:scale-[0.98] transition-all duration-300"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            QUERO PARTICIPAR DO GRUPO NO WHATSAPP
          </a>
        </div>
      </div>
    </section>

    <!-- ═══════════ ASSINATURA ═══════════ -->
    <section class="py-12 md:py-16">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
        <p class="text-gray-600 mb-4">
          Na história, Beatriz aprendeu que, com paciência e as estratégias certas, todas as letras podem encontrar o seu lugar.
        </p>
        <p class="text-gray-700 mb-2">
          Você já deu o primeiro passo ao baixar o ebook.
        </p>
        <p class="text-primary-dark font-semibold text-lg mb-8">
          O segundo é não enfrentar esse caminho sozinha.
        </p>

        <div class="inline-flex flex-col items-center gap-3">
          <img
            src={publicImg('images/guaciara-foto.webp')}
            alt="Guaciara Fornaciari"
            class="w-20 h-20 rounded-full object-cover shadow-md border-2 border-white"
            width="80"
            height="80"
            loading="lazy"
          />
          <div>
            <p class="text-gray-500 text-sm">Com carinho,</p>
            <p class="font-bold text-gray-800">Guaciara Fornaciari</p>
            <p class="text-sm text-gray-500">Fonoaudióloga · Especialista em Inclusão · +25 anos na Educação</p>
          </div>
        </div>
      </div>
    </section>

    <Footer />

  </main>
</Layout>
