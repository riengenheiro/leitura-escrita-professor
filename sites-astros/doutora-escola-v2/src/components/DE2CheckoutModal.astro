---
import { CHECKOUT_EMBED } from '../config/checkoutEmbed';
const { allowedOrigin, defaultSuccessUrl } = CHECKOUT_EMBED;
---
<div
  id="checkout-modal"
  class="checkout-modal fixed inset-0 z-[9999] hidden"
  role="dialog"
  aria-modal="true"
  aria-labelledby="checkout-modal-title"
  aria-hidden="true"
  data-allowed-origin={allowedOrigin}
  data-default-success-url={defaultSuccessUrl}
>
  <div class="checkout-modal-backdrop absolute inset-0 bg-black/60 backdrop-blur-sm" data-close-modal></div>

  <div class="checkout-modal-box absolute inset-4 md:inset-8 lg:inset-12 bg-white rounded-2xl shadow-2xl flex flex-col overflow-hidden">
    <header class="flex items-center justify-between gap-3 px-4 py-3 bg-gray-100 border-b border-gray-200 flex-shrink-0">
      <span id="checkout-modal-title" class="font-semibold text-gray-800">Finalizar compra</span>
      <div class="flex items-center gap-3">
        <a
          id="checkout-external-link"
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-green-600 hover:text-green-700 font-medium underline"
        >
          Abrir em nova aba
        </a>
        <button
          type="button"
          class="checkout-modal-close w-10 h-10 flex items-center justify-center rounded-full bg-gray-200 hover:bg-gray-300 text-gray-700 transition-colors"
          aria-label="Fechar"
          data-close-modal
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </header>

    <div class="flex-1 min-h-0 relative">
      <div
        id="checkout-loading"
        class="absolute inset-0 z-10 flex flex-col items-center justify-center gap-3 bg-white text-gray-600"
        role="status"
        aria-live="polite"
      >
        <div class="w-7 h-7 rounded-full border-2 border-gray-300 border-t-green-600 animate-spin"></div>
        <p class="text-sm font-medium">Carregando checkout seguro...</p>
      </div>
      <div
        id="checkout-error"
        class="absolute inset-0 z-20 hidden flex flex-col items-center justify-center gap-3 bg-white px-6 text-center"
        role="alert"
      >
        <p class="text-base font-semibold text-gray-800">Nao foi possivel carregar o checkout.</p>
        <p class="text-sm text-gray-600">Tente novamente ou abra em uma nova aba.</p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <button
            id="checkout-retry"
            type="button"
            class="px-4 py-2 rounded-lg bg-gray-800 hover:bg-black text-white text-sm font-semibold transition-colors"
          >
            Tentar novamente
          </button>
          <a
            id="checkout-fallback-link"
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            class="px-4 py-2 rounded-lg bg-green-600 hover:bg-green-700 text-white text-sm font-semibold transition-colors"
          >
            Abrir em nova aba
          </a>
        </div>
      </div>
      <iframe
        id="checkout-iframe"
        title="Checkout"
        class="absolute inset-0 w-full h-full border-0 opacity-0 transition-opacity"
        allow="payment"
      ></iframe>
    </div>
  </div>
</div>

<script is:inline>
  function appendLandingParamsToUrl(targetUrl) {
    var ALLOWED = ['aff','utm_source','utm_medium','utm_campaign','utm_content','utm_term','src','ref'];
    if (!targetUrl) return targetUrl;
    var landingParams, out;
    try { landingParams = new URL(window.location.href).searchParams; } catch(e) { return targetUrl; }
    try { out = new URL(targetUrl, window.location.origin); } catch(e) { return targetUrl; }
    var changed = false;
    landingParams.forEach(function(value, key) {
      if (ALLOWED.indexOf(key) === -1) return;
      if (!out.searchParams.has(key)) { out.searchParams.set(key, value); changed = true; }
    });
    return changed ? out.href : targetUrl;
  }

  (function () {
    const modal = document.getElementById('checkout-modal');
    if (!modal) return;

    const iframe = document.getElementById('checkout-iframe');
    const loading = document.getElementById('checkout-loading');
    const errorBox = document.getElementById('checkout-error');
    const retryButton = document.getElementById('checkout-retry');
    const closeButtons = modal.querySelectorAll('[data-close-modal]');
    const externalLink = document.getElementById('checkout-external-link');
    const fallbackLink = document.getElementById('checkout-fallback-link');

    let iframeLoaded = false;
    let preloadTimeout = null;
    let lastFocusedElement = null;
    let activeCheckoutUrl = '';
    let preloadedUrl = '';

    const defaultSuccessUrl = modal.getAttribute('data-default-success-url') || '/';
    const configAllowedOrigin = modal.getAttribute('data-allowed-origin') || '';
    const focusableSelector =
      'a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])';

    function isSafari() {
      const ua = navigator.userAgent;
      return (ua.includes('Safari') && !ua.includes('Chrome')) || /iPhone|iPad|iPod/.test(ua);
    }

    function parseOrigin(url) {
      try {
        return new URL(url, window.location.origin).origin;
      } catch {
        return '';
      }
    }

    function getAllowedOrigin() {
      if (configAllowedOrigin) return configAllowedOrigin;
      return parseOrigin(activeCheckoutUrl || preloadedUrl);
    }

    function getCheckoutUrlFromTrigger(el) {
      if (!el) return '';
      const dataUrl = el.getAttribute('data-checkout-url') || '';
      const href = el.getAttribute('href') || '';
      const url = dataUrl || href;
      if (!url || url === '#') return '';
      return appendLandingParamsToUrl(url);
    }

    /** Converte URL do embed para URL do checkout normal (nova aba / fallback) */
    function embedUrlToDirectUrl(embedUrl) {
      if (!embedUrl) return '';
      return embedUrl.replace('/checkout/embed_light.php', '/checkout/');
    }

    function updateExternalLinks(embedUrl) {
      const directUrl = embedUrlToDirectUrl(embedUrl);
      if (externalLink) externalLink.setAttribute('href', directUrl || '#');
      if (fallbackLink) fallbackLink.setAttribute('href', directUrl || '#');
    }

    function showLoading() {
      if (loading) loading.classList.remove('hidden');
      if (errorBox) errorBox.classList.add('hidden');
      if (iframe) iframe.classList.add('opacity-0');
    }

    function showIframe() {
      if (loading) loading.classList.add('hidden');
      if (errorBox) errorBox.classList.add('hidden');
      if (iframe) iframe.classList.remove('opacity-0');
    }

    function showError() {
      if (loading) loading.classList.add('hidden');
      if (errorBox) errorBox.classList.remove('hidden');
    }

    function clearPreloadTimeout() {
      if (preloadTimeout) {
        clearTimeout(preloadTimeout);
        preloadTimeout = null;
      }
    }

    function startPreloadTimeout() {
      clearPreloadTimeout();
      preloadTimeout = setTimeout(function () {
        if (!iframeLoaded) showError();
      }, 12000);
    }

    function getFocusableElements() {
      return modal.querySelectorAll(focusableSelector);
    }

    function trapFocus(e) {
      if (e.key !== 'Tab' || modal.classList.contains('hidden')) return;
      const focusableElements = getFocusableElements();
      if (!focusableElements.length) return;

      const first = focusableElements[0];
      const last = focusableElements[focusableElements.length - 1];

      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }

    function setModalOpenState() {
      modal.classList.remove('hidden');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      const firstCloseButton = closeButtons[0];
      if (firstCloseButton && typeof firstCloseButton.focus === 'function') {
        firstCloseButton.focus();
      }
    }

    function preloadCheckout(url) {
      if (!iframe || !url) return;
      if (preloadedUrl === url && iframeLoaded) return;

      activeCheckoutUrl = url;
      preloadedUrl = url;
      iframeLoaded = false;
      showLoading();
      startPreloadTimeout();
      updateExternalLinks(url);
      iframe.src = url;
    }

    function openModal(url) {
      if (!url) return;
      if (isSafari()) {
        window.open(embedUrlToDirectUrl(url), '_blank', 'noopener,noreferrer');
        return;
      }
      lastFocusedElement = document.activeElement;
      if (preloadedUrl !== url || !iframeLoaded) preloadCheckout(url);
      setModalOpenState();
    }

    function closeModal() {
      modal.classList.add('hidden');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      if (lastFocusedElement && typeof lastFocusedElement.focus === 'function') {
        lastFocusedElement.focus();
      }
    }

    if (iframe) {
      iframe.addEventListener('load', function () {
        iframeLoaded = true;
        clearPreloadTimeout();
        showIframe();
      });
    }

    const openTriggers = document.querySelectorAll('.js-open-checkout-modal');
    openTriggers.forEach(function (el) {
      el.addEventListener('click', function (e) {
        const checkoutUrl = getCheckoutUrlFromTrigger(el);
        if (!checkoutUrl) return;
        e.preventDefault();
        openModal(checkoutUrl);
      });

      let hoverTimer;
      el.addEventListener('mouseenter', function () {
        const checkoutUrl = getCheckoutUrlFromTrigger(el);
        hoverTimer = setTimeout(function () {
          preloadCheckout(checkoutUrl);
        }, 300);
      });
      el.addEventListener('mouseleave', function () {
        clearTimeout(hoverTimer);
      });
      el.addEventListener(
        'touchstart',
        function () {
          const checkoutUrl = getCheckoutUrlFromTrigger(el);
          preloadCheckout(checkoutUrl);
        },
        { passive: true, once: true }
      );
    });

    const pricingSection = document.getElementById('preco');
    if (pricingSection && typeof IntersectionObserver !== 'undefined') {
      const observer = new IntersectionObserver(
        function (entries) {
          if (!entries[0].isIntersecting) return;
          const firstTrigger = document.querySelector('.js-open-checkout-modal');
          const firstCheckoutUrl = getCheckoutUrlFromTrigger(firstTrigger);
          preloadCheckout(firstCheckoutUrl);
          observer.disconnect();
        },
        { rootMargin: '100px', threshold: 0.1 }
      );
      observer.observe(pricingSection);
    }

    closeButtons.forEach(function (el) {
      el.addEventListener('click', closeModal);
    });

    modal.addEventListener('click', function (e) {
      if (e.target.classList.contains('checkout-modal-backdrop')) closeModal();
    });

    window.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
      trapFocus(e);
    });

    if (retryButton) {
      retryButton.addEventListener('click', function () {
        if (!activeCheckoutUrl) return;
        preloadCheckout(activeCheckoutUrl);
      });
    }

    window.addEventListener('message', function (event) {
      const expectedOrigin = getAllowedOrigin();
      if (expectedOrigin && event.origin !== expectedOrigin) return;
      if (iframe && event.source !== iframe.contentWindow) return;

      const data = event.data;
      if (data && data.type === 'CHECKOUT_SUCCESS') {
        closeModal();
        window.location.href = typeof data.url === 'string' && data.url ? data.url : defaultSuccessUrl;
      }
    });
  })();
</script>
