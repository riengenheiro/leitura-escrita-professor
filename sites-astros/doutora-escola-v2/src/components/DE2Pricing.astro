---
import { PRICE_ANCHOR, PRICE_BASIC, PRICE_COMPLETO_ANCHOR, PRICE_COMPLETO, formatPrice, CHECKOUT_BASIC, CHECKOUT_COMPLETO } from '../config/pricing';
const bonusCompleto = [
  'Reunião de Pais Produtiva: Como Conduzir sem Conflitos',
  'Projeto Pedagógico Inovador: Do Papel à Prática',
  'Lidando com Alunos que Não Fazem Nada: Estratégias que Funcionam',
  'Fim de Semana do Professor: Como Desconectar Verdadeiramente',
  'Calendário Escolar sem Estresse: Organizando Eventos e Datas',
  'Campos de Experiências na Educação Especial de Adultos',
];
---
<section id="preco" class="py-16 md:py-24 px-6 scroll-mt-4 relative overflow-hidden" style="background: linear-gradient(180deg, #f8fafc 0%, #e2e8f0 50%, #f1f5f9 100%);">
  <div class="absolute inset-0 pointer-events-none opacity-30">
    <div class="absolute top-20 right-0 w-96 h-96 rounded-full bg-[#2C3E99]" style="filter: blur(120px);"></div>
    <div class="absolute bottom-20 left-0 w-80 h-80 rounded-full bg-[#FF9800]" style="filter: blur(100px);"></div>
  </div>
  <div class="max-w-5xl mx-auto relative z-10">
    <h2 class="text-3xl md:text-4xl font-extrabold text-center text-gray-900 mb-2">Escolha seu plano</h2>
    <p class="text-center text-[#2C3E99] font-bold mb-10">76% das professoras escolhem o COMPLETO</p>
    <div class="grid md:grid-cols-2 gap-8 items-stretch">
      <div class="rounded-3xl border-2 border-gray-200 bg-white p-8 shadow-xl hover:shadow-2xl hover:border-[#2C3E99]/30 transition-all duration-300 flex flex-col">
        <p class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-4">Básico</p>
        <div class="rounded-2xl bg-gray-100 py-4 px-4 mb-6">
          <p class="line-through text-gray-400 text-sm">De R$ {PRICE_ANCHOR},00</p>
          <p class="text-4xl font-black text-gray-900">R$ {formatPrice(PRICE_BASIC)},00</p>
          <p class="text-gray-600 text-sm mt-1">ou 3x de R$ 15,67 sem juros</p>
        </div>
        <ul class="space-y-3 text-gray-700 flex-1">
          <li class="flex items-center gap-2"><span class="text-[#4CAF50] font-bold">✓</span> Ebook completo (360 páginas, 60 por bloco)</li>
          <li class="flex items-center gap-2"><span class="text-[#4CAF50] font-bold">✓</span> 25+ atividades detalhadas</li>
          <li class="flex items-center gap-2"><span class="text-[#4CAF50] font-bold">✓</span> 3 projetos interdisciplinares</li>
          <li class="flex items-center gap-2"><span class="text-[#4CAF50] font-bold">✓</span> Templates e checklists</li>
          <li class="flex items-center gap-2"><span class="text-[#4CAF50] font-bold">✓</span> Acesso vitalício</li>
        </ul>
        <a href={CHECKOUT_BASIC} class="mt-6 block w-full text-center bg-gradient-to-r from-[#2C3E99] to-[#1a2570] hover:from-[#3d4fb3] hover:to-[#2C3E99] text-white font-bold py-4 rounded-2xl shadow-lg hover:shadow-xl hover:scale-[1.02] active:scale-[0.98] transition-all duration-200">QUERO O EBOOK</a>
      </div>
      <div class="rounded-3xl border-4 border-[#FF9800] p-8 shadow-2xl relative flex flex-col" style="background: linear-gradient(180deg, #fff9f0 0%, #fff 30%, #fffbf5 100%); box-shadow: 0 25px 50px -12px rgba(255, 152, 0, 0.25);">
        <span class="absolute -top-4 left-1/2 -translate-x-1/2 bg-gradient-to-r from-[#FF9800] to-[#F57C00] text-white text-sm font-black px-5 py-1.5 rounded-full shadow-lg">MAIS ESCOLHIDO</span>
        <p class="text-sm font-bold text-[#2C3E99] uppercase tracking-wider mt-2 mb-4">Completo com Bônus</p>
        <div class="rounded-2xl bg-gradient-to-r from-[#FF9800]/20 to-[#F57C00]/10 border-2 border-[#FF9800]/40 py-5 px-4 mb-6">
          <p class="line-through text-gray-500 text-sm">De R$ {PRICE_COMPLETO_ANCHOR},00</p>
          <p class="text-4xl font-black text-[#2C3E99]">R$ {formatPrice(PRICE_COMPLETO)},00</p>
          <p class="text-gray-700 text-sm font-semibold mt-1">ou 10x de R$ 11,90 sem juros</p>
          <span class="inline-block mt-2 px-3 py-0.5 rounded-full bg-[#4CAF50] text-white text-xs font-bold">Economize R$ 178</span>
        </div>
        <p class="text-sm text-gray-800 font-bold mb-2">Tudo do Básico + 6 bônus exclusivos:</p>
        <ul class="space-y-1.5 text-sm text-gray-700 flex-1 overflow-y-auto max-h-40">
          {bonusCompleto.map((b) => (
            <li class="flex items-start gap-2">🎁 {b}</li>
          ))}
        </ul>
        <a href={CHECKOUT_COMPLETO} class="mt-6 block w-full text-center bg-gradient-to-r from-[#FF9800] to-[#F57C00] hover:from-amber-400 hover:to-[#FF9800] text-white font-black py-4 rounded-2xl shadow-[0_8px_25px_rgba(255,152,0,0.4)] hover:shadow-[0_12px_35px_rgba(255,152,0,0.5)] hover:scale-[1.02] active:scale-[0.98] transition-all duration-200 min-h-[56px] flex items-center justify-center border-2 border-amber-600/30">
          QUERO O COMPLETO COM BÔNUS!
        </a>
        <p class="text-xs text-center text-amber-700 font-semibold mt-3">⏰ Oferta por tempo limitado</p>
      </div>
    </div>
  </div>
</section>
