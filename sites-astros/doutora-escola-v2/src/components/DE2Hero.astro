---
import { PRICE_ANCHOR, PRICE_BASIC, formatPrice, CHECKOUT_BASIC } from '../config/pricing';
import { DE2HeroCountdown } from './DE2HeroCountdown';
---
<section class="bg-gradient-to-b from-[#2C3E99] to-[#1a2570] text-white py-10 md:py-16 px-6">
  <div class="max-w-6xl mx-auto">
    <DE2HeroCountdown client:load />
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="text-center lg:text-left">
        <p class="text-[#FF9800] font-bold uppercase tracking-wider text-sm md:text-base mb-3">VERSÃO 2.0 AMPLIADA</p>
        <p class="text-xl md:text-2xl text-white/90 mb-2">Agora com 3x MAIS conteúdo!</p>
        <h1 class="text-2xl md:text-3xl lg:text-4xl font-extrabold mb-4 leading-tight">
          Para professoras de Educação Infantil<br />
          Cansada de planejar sozinha, sem ideias práticas<br />
          e com zero reconhecimento?
        </h1>
        <p class="text-base md:text-lg text-white/95 mb-6">
          Mais de 2.000 professoras já transformaram suas aulas. Atividades PASSO A PASSO, 3 projetos de 4 semanas e templates editáveis.
        </p>
        <div class="mb-8 inline-block rounded-2xl bg-white/10 backdrop-blur-sm border-2 border-[#FF9800]/50 px-6 py-5 shadow-2xl">
          <p class="text-white/90 text-sm font-semibold mb-1">Livro Digital + Projetos + Templates</p>
          <p class="line-through text-white/60 text-lg">DE R$ {PRICE_ANCHOR},00</p>
          <p class="text-4xl md:text-5xl font-black text-[#FF9800] drop-shadow-lg leading-none mt-1">R$ {formatPrice(PRICE_BASIC)},00</p>
          <p class="text-white font-bold text-sm mt-1">ou 3x de R$ 15,67 <span class="text-white/80 font-normal">sem juros</span></p>
          <span class="inline-block mt-3 px-3 py-1 rounded-full bg-[#4CAF50] text-white text-xs font-bold">Economize R$ 100</span>
        </div>
        <a href={CHECKOUT_BASIC} class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-[#FF9800] to-[#F57C00] hover:from-amber-400 hover:to-[#FF9800] text-white font-black text-lg px-10 py-4 rounded-2xl shadow-[0_8px_30px_rgba(255,152,0,0.5)] hover:shadow-[0_12px_40px_rgba(255,152,0,0.6)] hover:scale-105 active:scale-100 transition-all duration-300 min-h-[60px] border-2 border-white/30">
          QUERO A VERSÃO 2.0 AGORA!
        </a>
        <div class="flex flex-wrap justify-center lg:justify-start gap-4 mt-6 text-sm text-white/90">
          <span class="flex items-center gap-1">⚡ Acesso imediato</span>
          <span class="flex items-center gap-1">🔒 Compra segura</span>
          <span class="flex items-center gap-1">✅ Garantia 7 dias</span>
          <span class="flex items-center gap-1">📱 Acesso vitalício</span>
        </div>
      </div>
      <div class="flex justify-center lg:justify-end order-first lg:order-none">
        <div class="relative w-full max-w-sm aspect-[1024/1536] rounded-2xl overflow-hidden border-4 border-[#FF9800] shadow-2xl bg-white/10 flex items-center justify-center">
          <img
            src="/images/v2/01-hero-mockup.webp"
            alt="Ebook Ideias para os Campos de Experiências V2.0 - Doutora Escola"
            class="w-full h-full object-cover object-center"
            width="1024"
            height="1536"
          />
        </div>
      </div>
    </div>
  </div>
</section>
