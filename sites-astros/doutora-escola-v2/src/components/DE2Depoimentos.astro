---
const depoimentos = [
  { texto: 'A versão 2.0 está MUITO mais completa! Os projetos de 4 semanas me salvaram.', nome: 'Renata Costa', local: 'Belo Horizonte - MG', iniciais: 'RC' },
  { texto: 'Os templates editáveis valem o material inteiro! Não perco mais tempo criando fichas do zero.', nome: 'Amanda Ferreira', local: 'Recife - PE', iniciais: 'AF' },
  { texto: 'Comprei a V1 e estava bom. Mas a V2 está em OUTRO NÍVEL! Vale cada centavo.', nome: 'Luciana Rocha', local: 'Goiânia - GO', iniciais: 'LR' },
];
---
<section class="py-16 md:py-20 bg-surface px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl md:text-3xl font-extrabold text-center text-gray-900 mb-4">O que dizem as professoras que já usam</h2>
    <p class="text-center text-gray-600 mb-12">Avaliação 4.9/5 - Mais de 2.000 professoras</p>
    <div class="grid md:grid-cols-3 gap-8">
      {depoimentos.map((d) => (
        <div class="bg-white rounded-xl p-6 shadow-md border border-gray-200 flex flex-col items-center text-center">
          <div class="w-16 h-16 rounded-full bg-[#2C3E99] text-white font-bold text-lg flex items-center justify-center mb-4 shadow-md">
            {d.iniciais}
          </div>
          <p class="text-gray-700 mb-4 flex-1">"{d.texto}"</p>
          <p class="font-semibold text-gray-900">{d.nome}</p>
          <p class="text-sm text-gray-500">Professora em {d.local}</p>
        </div>
      ))}
    </div>
  </div>
</section>
