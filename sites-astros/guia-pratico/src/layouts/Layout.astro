---
import '../styles/global.css';

const title = "Guia Prático de Dificuldades Escolares — Método Doutora Escola";
const description = "Um método prático para observar, nomear e agir com segurança diante de dificuldades escolares — sem precisar ser especialista clínica. Ebook + Curso (8h) com checklists completos.";
const siteUrl = "https://doutoraescola.com.br";
---
<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0F4C75" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="pt_BR" />
    <link rel="preconnect" href="https://fm.doutoraescola.com.br" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,600&display=swap" />
  </head>
  <body>
    <slot />
    <script is:inline data-cfasync="false">
      (function () {
        var ALLOWED = ['aff', 'utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term', 'src', 'ref'];
        var HOST_MATCH = /(^|\.)((fm\.doutoraescola\.com\.br)|(pay\.kiwify\.com(\.br)?)|(voomp\.com\.br))$/;

        function appendLandingParamsToUrl(targetUrl) {
          if (!targetUrl) return targetUrl;
          var landingParams;
          var out;
          try {
            landingParams = new URL(window.location.href).searchParams;
            out = new URL(targetUrl, window.location.origin);
          } catch (e) {
            return targetUrl;
          }
          landingParams.forEach(function (value, key) {
            if (ALLOWED.indexOf(key) === -1) return;
            if (!out.searchParams.has(key)) out.searchParams.set(key, value);
          });
          return out.href;
        }

        document.addEventListener(
          'click',
          function (event) {
            var target = event.target;
            if (!(target instanceof Element)) return;
            var link = target.closest('a[href]');
            if (!link) return;

            var href = link.getAttribute('href');
            if (!href || href === '#' || href.indexOf('javascript:') === 0) return;

            var parsed;
            try {
              parsed = new URL(href, window.location.origin);
            } catch (e) {
              return;
            }
            if (!HOST_MATCH.test(parsed.hostname)) return;

            link.setAttribute('href', appendLandingParamsToUrl(parsed.href));
          },
          true
        );
      })();
    </script>
  </body>
</html>
