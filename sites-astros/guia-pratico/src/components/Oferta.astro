---
import { CHECKOUT_EMBED_URL } from '../config/checkoutEmbed';

const itens = [
  { emoji: "📗", texto: "Ebook: Guia de Dificuldades Escolares" },
  { emoji: "📘", texto: "Ebook: Pilares da Sondagem — Método Doutora Escola" },
  { emoji: "📋", texto: "Checklist de Sondagem — Educação Infantil" },
  { emoji: "📋", texto: "Checklist de Sondagem — Ensino Fundamental" },
  { emoji: "🎬", texto: "Curso em Vídeo (8 horas) — Dificuldades Escolares na Prática" },
  { emoji: "🛑", texto: "Bônus: Como Acabar com as Interrupções em Sala" },
  { emoji: "⏱️", texto: "Bônus: Planejamento de Aulas em 1 Hora — Step-by-Step" },
];
---

<section id="preco" class="bg-white py-20 px-6">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-[#0F4C75] text-center mb-12">
      Tudo que você recebe com um único acesso:
    </h2>

    <div class="bg-[#f8f9fa] rounded-2xl border border-gray-200 p-8 shadow-sm mb-10">
      <ul class="space-y-3 mb-8">
        {itens.map((item) => (
          <li class="flex items-center gap-3 text-gray-800">
            <span class="text-[#16A34A] font-bold shrink-0">✓</span>
            <span class="text-sm md:text-base">{item.emoji} {item.texto}</span>
          </li>
        ))}
      </ul>

      <div class="border-t border-gray-300 pt-7 text-center">
        <p class="text-gray-500 text-sm mb-1">Investimento único</p>
        <p class="text-5xl font-extrabold text-[#0F4C75] mb-1">R$ 47,00</p>
        <p class="text-gray-500 text-base mb-1">pagamento único · acesso imediato</p>
        <p class="text-gray-400 text-xs italic mt-2">
          Menos do que o custo de uma consulta pedagógica de 40 minutos — e você usa o material o ano inteiro.
        </p>
      </div>
    </div>

    <div class="text-center">
      <a href={CHECKOUT_EMBED_URL} class="js-open-checkout-modal btn-cta text-lg px-10 py-5 shadow-lg w-full sm:w-auto block sm:inline-block">
        Verificar se este método faz sentido para você
      </a>
      <p class="text-gray-400 text-xs mt-3">Acesso imediato após confirmação do pagamento</p>
    </div>
  </div>
</section>
