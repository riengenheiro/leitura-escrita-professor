---
import { PRICE_BASIC, formatPrice } from '../../config/pricing';

interface Props { price?: number }
const { price } = Astro.props;
const pagePrice = price ?? PRICE_BASIC;
---
<section class="bg-gradient-to-b from-red-600 to-red-700 text-white py-16 md:py-20">
  <div class="max-w-4xl mx-auto px-6 text-center">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold mb-8">Última Chamada!</h2>
    <p class="text-xl md:text-2xl mb-4 opacity-95">Não continue perdendo tempo, energia e oportunidades.</p>
    <p class="text-xl md:text-2xl mb-10 opacity-95">Garanta agora o material que vai transformar seu planejamento!</p>
    <p class="text-2xl md:text-3xl font-bold mb-10">Ideias por apenas <span class="text-yellow-400 text-3xl md:text-4xl">R$ {formatPrice(pagePrice, true)}</span></p>
    <a href="#opcoes" class="inline-block px-12 py-6 bg-orange-500 hover:opacity-90 text-black text-xl md:text-2xl font-extrabold rounded-xl transition-all shadow-2xl uppercase">Garantir meu exemplar agora!</a>
  </div>
</section>
