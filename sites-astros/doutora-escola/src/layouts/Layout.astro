---
import '../styles/global.css';
import { PRICE_BASIC, PRICE_ANCHOR, formatPrice } from '../config/pricing';

interface Props {
  /** Preço da página (para testes /v1=17, /v2=27, etc). Omitir = R$ 10 (principal). */
  price?: number;
}

const { price } = Astro.props;
const pagePrice = price ?? PRICE_BASIC;

const title = `Doutora Escola | Ideias para os Campos de Experiências da BNCC - R$ ${formatPrice(pagePrice, true)}`;
const description = `Cansada de procurar ideias novas? Mais de 2.000 professoras já transformaram suas aulas com este guia prático, direto e totalmente alinhado à BNCC. De R$ ${PRICE_ANCHOR} por apenas R$ ${pagePrice}!`;

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Ideias para Trabalhar os Campos de Experiências da BNCC',
  description: 'Guia prático e direto alinhado à BNCC. Mais de 2.000 professoras já transformaram suas aulas com este material.',
  image: 'https://ideias.doutoraescola.com.br/images/doutora-escola/01-hero.png',
  brand: { '@type': 'Organization', name: 'Doutora Escola', description: 'G&R Instituto Educacional - Especialistas em Educação' },
  offers: {
    '@type': 'Offer',
    url: 'https://ideias.doutoraescola.com.br/',
    priceCurrency: 'BRL',
    price: pagePrice.toFixed(2),
    priceValidUntil: '2026-12-31',
    availability: 'https://schema.org/InStock',
    seller: { '@type': 'Organization', name: 'Doutora Escola' },
  },
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: '2000' },
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Doutora Escola - Ideias para os Campos de Experiências',
  description: 'Livro digital com ideias práticas para trabalhar os Campos de Experiência da BNCC',
  url: 'https://ideias.doutoraescola.com.br/',
  author: { '@type': 'Person', name: 'Dra. Guaciara Fornaciari', jobTitle: 'Fonoaudióloga e Especialista em Educação' },
};

const ogTitle = `Ideias para Trabalhar os Campos de Experiências da BNCC - R$ ${formatPrice(pagePrice, true)}`;
---
<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favico.png" />
    <link rel="apple-touch-icon" href="/favico.png" />
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content="BNCC, Campos de Experiências, educação infantil, planejamento escolar, atividades pedagógicas, ideias para professores, Dra. Guaciara Fornaciari, Doutora Escola, planejamento de aulas" />
    <meta name="author" content="Dra. Guaciara Fornaciari - Doutora Escola" />
    <meta name="robots" content="index, follow" />
    <meta name="language" content="Portuguese" />
    <meta name="revisit-after" content="7 days" />
    <link rel="canonical" href="https://ideias.doutoraescola.com.br/" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://ideias.doutoraescola.com.br/" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content="Guia prático e direto alinhado à BNCC. Mais de 2.000 professoras já transformaram suas aulas. Economize tempo no planejamento e ganhe reconhecimento!" />
    <meta property="og:image" content="https://ideias.doutoraescola.com.br/images/doutora-escola/01-hero.png" />
    <meta property="og:image:secure_url" content="https://ideias.doutoraescola.com.br/images/doutora-escola/01-hero.png" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Livro Digital - Ideias para trabalhar os Campos de Experiências da BNCC" />
    <meta property="og:site_name" content="Doutora Escola" />
    <meta property="og:locale" content="pt_BR" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://ideias.doutoraescola.com.br/" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content="Guia prático e direto alinhado à BNCC. Mais de 2.000 professoras já transformaram suas aulas. Economize tempo no planejamento!" />
    <meta name="twitter:image" content="https://ideias.doutoraescola.com.br/images/doutora-escola/01-hero.png" />
    <meta name="twitter:image:alt" content="Livro Digital - Ideias para trabalhar os Campos de Experiências da BNCC" />
    <meta name="theme-color" content="#10b981" />
    <meta name="msapplication-TileColor" content="#10b981" />
    <meta name="format-detection" content="telephone=no" />
    <script is:inline>
      (function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];})(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://connect.facebook.net" crossorigin />
    <link rel="dns-prefetch" href="https://www.facebook.com" />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" /></noscript>
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
  </head>
  <body data-page-price={pagePrice}>
    <!-- Garante preço certo mesmo se o servidor servir index.html para /v1, /v2, etc (fallback SPA) -->
    <script is:inline>
      (function(){
        var path = typeof location !== 'undefined' && location.pathname;
        var map = {'/v1':17,'/v2':27,'/v3':37,'/v4':47};
        if (path && map[path] !== undefined) document.body.dataset.pagePrice = map[path];
      })();
    </script>
    <slot />
  </body>
</html>
