  <script is:inline>
    // TIMER
    let totalSeconds = 14 * 60 + 55;
    function updateTimer() {
      if (totalSeconds <= 0) { totalSeconds = 14 * 60 + 55; }
      const m = Math.floor(totalSeconds / 60);
      const s = totalSeconds % 60;
      document.getElementById('tm').textContent = String(m).padStart(2, '0');
      document.getElementById('ts').textContent = String(s).padStart(2, '0');
      totalSeconds--;
    }
    updateTimer();
    setInterval(updateTimer, 1000);

    // FAQ TOGGLE
    document.querySelectorAll('.faq-item').forEach(function(item) {
      item.querySelector('.faq-q').addEventListener('click', function() {
        item.classList.toggle('open');
      });
    });
  </script>

  <script is:inline>
    (function () {
      var ALLOWED = ['aff','utm_source','utm_medium','utm_campaign','utm_content','utm_term','src','ref'];
      function appendLandingParamsToUrl(targetUrl) {
        if (!targetUrl) return targetUrl;
        var landingParams, out;
        try { landingParams = new URL(window.location.href).searchParams; } catch(e) { return targetUrl; }
        try { out = new URL(targetUrl, window.location.origin); } catch(e) { return targetUrl; }
        var changed = false;
        landingParams.forEach(function(value, key) {
          if (ALLOWED.indexOf(key) === -1) return;
          if (!out.searchParams.has(key)) { out.searchParams.set(key, value); changed = true; }
        });
        return changed ? out.href : targetUrl;
      }
      document.querySelectorAll('a[href*="fm.doutoraescola.com.br/checkout"]').forEach(function (el) {
        var h = el.getAttribute('href');
