---
const title = 'Sondagem na Prática — Guia Completo para Professoras';
const description = 'O guia passo a passo que transforma seu diagnóstico em planejamento real — sem jargão técnico, sem horas perdidas. Para professoras de Educação Infantil e Séries Iniciais.';
const siteUrl = 'https://sondagem.doutoraescola.com.br';
// Imagem de compartilhamento: public/images/sondagem/og-sondagem.webp (1200×630 px)
const ogImage = `${siteUrl}/images/sondagem/og-sondagem.webp`;
import { FACEBOOK_PIXEL_ID } from '../config/facebookPixel';
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <!-- Meta Pixel (Facebook) - snippet oficial no head -->
  <script is:inline define:vars={{ FACEBOOK_PIXEL_ID }}>
    !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', FACEBOOK_PIXEL_ID);
    fbq('track', 'PageView');
  </script>
  <noscript><img height="1" width="1" style="display:none" alt="" src={`https://www.facebook.com/tr?id=${FACEBOOK_PIXEL_ID}&ev=PageView&noscript=1`} /></noscript>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="sondagem, educação infantil, séries iniciais, hipóteses de escrita, planejamento, diagnóstico, Dra. Guaciara Fornaciari, Doutora Escola" />
  <meta name="author" content="Dra. Guaciara Fornaciari - Doutora Escola" />
  <meta name="robots" content="index, follow" />
  <link rel="icon" href="/images/favico.png" type="image/png" />
  <link rel="apple-touch-icon" href="/images/favico.png" />
  <link rel="canonical" href={`${siteUrl}/`} />

  <!-- Open Graph (Facebook, WhatsApp, LinkedIn) -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={siteUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:secure_url" content={ogImage} />
  <meta property="og:image:type" content="image/webp" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Sondagem na Prática — Guia Completo para Professoras. Doutora Escola." />
  <meta property="og:site_name" content="Doutora Escola" />
  <meta property="og:locale" content="pt_BR" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content={siteUrl} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:image:alt" content="Sondagem na Prática — Guia Completo para Professoras. Doutora Escola." />

  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,400;0,700;0,900;1,400&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="preconnect" href="https://connect.facebook.net" crossorigin />
  <link rel="dns-prefetch" href="https://www.facebook.com" />
  <style is:global>
    :root {
      --navy: #0D2B55;
      --blue: #1A5EA8;
      --sky: #5BA4D4;
      --accent: #F4A623;
      --mint: #E8F4F0;
      --cream: #FEF9F2;
      --white: #ffffff;
      --gray: #64748b;
      --light: #F0F6FF;
      --red-alert: #E53E3E;
      --green: #2D7D46;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--cream);
      color: var(--navy);
      line-height: 1.6;
    }

    .timer-bar {
      background: var(--navy);
      color: white;
      text-align: center;
      padding: 12px 20px;
      font-size: 0.9rem;
      font-weight: 500;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      flex-wrap: wrap;
    }
    .timer-units {
      display: flex;
      gap: 10px;
      align-items: center;
    }
    .timer-unit {
      background: var(--accent);
      color: var(--navy);
      font-family: 'Fraunces', serif;
      font-weight: 900;
      font-size: 1.4rem;
      padding: 4px 12px;
      border-radius: 6px;
      min-width: 48px;
      text-align: center;
    }
    .timer-label {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      opacity: 0.8;
      display: block;
      margin-top: 2px;
    }

    .hero {
      background: linear-gradient(135deg, var(--navy) 0%, #1A3A6B 60%, #1A5EA8 100%);
      color: white;
      padding: 60px 20px 80px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .hero .hero-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: center;
      max-width: 1000px;
      margin: 0 auto;
      text-align: left;
      position: relative;
      z-index: 1;
    }
    .hero .hero-grid .hero-content { text-align: center; }
    .hero .hero-mockup-wrap {
      text-align: center;
      position: relative;
    }
    .hero .hero-mockup-img {
      width: 100%;
      max-width: 320px;
      height: auto;
      border-radius: 12px;
      box-shadow: 0 24px 60px rgba(0,0,0,0.35);
      display: block;
      margin: 0 auto;
    }
    @media (max-width: 768px) {
      .hero .hero-grid {
        grid-template-columns: 1fr;
        gap: 32px;
        text-align: center;
      }
      .hero .hero-grid .hero-content { text-align: center; }
      .hero .hero-mockup-img { max-width: 260px; }
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -60px; right: -60px;
      width: 300px; height: 300px;
      background: rgba(91,164,212,0.12);
      border-radius: 50%;
    }
    .hero::after {
      content: '';
      position: absolute;
      bottom: -80px; left: -40px;
      width: 250px; height: 250px;
      background: rgba(244,166,35,0.08);
      border-radius: 50%;
    }
    .hero-tag {
      display: inline-block;
      background: rgba(244,166,35,0.2);
      border: 1px solid rgba(244,166,35,0.5);
      color: var(--accent);
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 6px 16px;
      border-radius: 100px;
      margin-bottom: 24px;
    }
    .hero h1 {
      font-family: 'Fraunces', serif;
      font-size: clamp(2rem, 5vw, 3.4rem);
      font-weight: 900;
      line-height: 1.15;
      max-width: 780px;
      margin: 0 auto 20px;
    }
    .hero h1 em {
      color: var(--accent);
      font-style: normal;
    }
    .hero p.subtitle {
      font-size: clamp(1rem, 2.5vw, 1.2rem);
      opacity: 0.85;
      max-width: 580px;
      margin: 0 auto 36px;
    }
    .hero-social-proof {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      font-size: 0.9rem;
      opacity: 0.85;
      margin-bottom: 40px;
    }
    .stars { color: var(--accent); letter-spacing: 2px; }

    .cta-btn {
      display: inline-block;
      background: var(--accent);
      color: var(--navy);
      font-family: 'Fraunces', serif;
      font-size: 1.1rem;
      font-weight: 700;
      padding: 18px 40px;
      border-radius: 10px;
      text-decoration: none;
      cursor: pointer;
      border: none;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 6px 24px rgba(244,166,35,0.35);
    }
    .cta-btn:hover { transform: translateY(-2px); box-shadow: 0 10px 32px rgba(244,166,35,0.45); }
    .cta-sub {
      font-size: 0.8rem;
      opacity: 0.7;
      margin-top: 10px;
    }

    .pain {
      background: white;
      padding: 70px 20px;
      text-align: center;
    }
    .container { max-width: 860px; margin: 0 auto; }
    .section-tag {
      display: inline-block;
      color: var(--sky);
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 14px;
    }
    .pain h2 {
      font-family: 'Fraunces', serif;
      font-size: clamp(1.7rem, 4vw, 2.6rem);
      font-weight: 900;
      margin-bottom: 16px;
      line-height: 1.2;
    }
    .pain p.lead {
      font-size: 1.1rem;
      color: var(--gray);
      max-width: 620px;
      margin: 0 auto 48px;
    }
    .pain-cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
      text-align: left;
      margin-bottom: 48px;
    }
    .pain-card {
      background: var(--light);
      border-left: 4px solid var(--sky);
      border-radius: 10px;
      padding: 22px 20px;
    }
    .pain-card .icon { font-size: 1.6rem; margin-bottom: 10px; }
    .pain-card p { font-size: 0.95rem; color: #374151; line-height: 1.5; }
    .pain-highlight {
      background: var(--mint);
      border-radius: 12px;
      padding: 28px 32px;
      font-size: 1.05rem;
      font-weight: 500;
      color: var(--navy);
      max-width: 680px;
      margin: 0 auto;
      border: 1px solid rgba(91,164,212,0.2);
    }
    .pain-highlight strong { color: var(--blue); }

    .solution {
      background: var(--light);
      padding: 70px 20px;
    }
    .solution-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: center;
    }
    @media(max-width: 680px) { .solution-grid { grid-template-columns: 1fr; } }
    .solution h2 {
      font-family: 'Fraunces', serif;
      font-size: clamp(1.6rem, 3.5vw, 2.4rem);
      font-weight: 900;
      margin-bottom: 20px;
      line-height: 1.2;
    }
    .solution p {
      color: var(--gray);
      font-size: 1.02rem;
      margin-bottom: 16px;
    }
    .check-list { list-style: none; }
    .check-list li {
      padding: 10px 0;
      padding-left: 30px;
      position: relative;
      font-size: 0.98rem;
      border-bottom: 1px solid rgba(0,0,0,0.06);
    }
    .check-list li::before {
      content: '✓';
      position: absolute;
      left: 0;
      color: var(--green);
      font-weight: 700;
    }
    .book-mockup {
      background: linear-gradient(145deg, #1A5EA8, #0D2B55);
      border-radius: 16px;
      padding: 40px 32px;
      color: white;
      text-align: center;
      box-shadow: 0 20px 60px rgba(13,43,85,0.3);
      position: relative;
    }
    .book-mockup .book-title {
      font-family: 'Fraunces', serif;
      font-size: 1.4rem;
      font-weight: 900;
      margin-bottom: 8px;
      line-height: 1.2;
    }
    .book-mockup .book-sub {
      font-size: 0.85rem;
      opacity: 0.75;
      margin-bottom: 24px;
    }
    .book-badge {
      display: inline-block;
      background: var(--accent);
      color: var(--navy);
      font-size: 0.75rem;
      font-weight: 700;
      padding: 4px 12px;
      border-radius: 100px;
      margin-bottom: 8px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .chapters {
      text-align: left;
      margin-top: 20px;
    }
    .chapter-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 0;
      border-bottom: 1px solid rgba(255,255,255,0.1);
      font-size: 0.85rem;
      opacity: 0.9;
    }
    .chapter-num {
      background: rgba(255,255,255,0.15);
      width: 26px; height: 26px;
      border-radius: 6px;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.75rem;
      font-weight: 700;
      flex-shrink: 0;
    }

    .inside {
      background: white;
      padding: 70px 20px;
      text-align: center;
    }
    .inside h2 {
      font-family: 'Fraunces', serif;
      font-size: clamp(1.6rem, 3.5vw, 2.4rem);
      font-weight: 900;
      margin-bottom: 12px;
    }
    .inside p.lead {
      color: var(--gray);
      font-size: 1.05rem;
      max-width: 560px;
      margin: 0 auto 48px;
    }
    .inside-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 20px;
      text-align: left;
    }
    .inside-card {
      border: 1px solid rgba(91,164,212,0.2);
      border-radius: 12px;
      padding: 24px;
      transition: box-shadow 0.2s, transform 0.2s;
    }
    .inside-card:hover { box-shadow: 0 8px 30px rgba(26,94,168,0.1); transform: translateY(-3px); }
    .inside-card .ic-icon { font-size: 1.8rem; margin-bottom: 12px; }
    .inside-card h3 { font-family: 'Fraunces', serif; font-size: 1.05rem; font-weight: 700; margin-bottom: 8px; color: var(--navy); }
    .inside-card p { font-size: 0.9rem; color: var(--gray); }

    .testimonials {
      background: var(--navy);
      padding: 70px 20px;
      color: white;
      text-align: center;
    }
    .testimonials h2 {
      font-family: 'Fraunces', serif;
      font-size: clamp(1.6rem, 3.5vw, 2.4rem);
      font-weight: 900;
      margin-bottom: 12px;
      color: white;
    }
    .rating-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      margin-bottom: 48px;
      font-size: 0.95rem;
      opacity: 0.85;
    }
    .rating-big {
      font-family: 'Fraunces', serif;
      font-size: 2rem;
      font-weight: 900;
      color: var(--accent);
    }
    .test-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 20px;
      text-align: left;
    }
    .test-card {
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 12px;
      padding: 24px;
    }
    .test-stars { color: var(--accent); margin-bottom: 10px; font-size: 0.9rem; }
    .test-text { font-size: 0.95rem; opacity: 0.9; margin-bottom: 16px; line-height: 1.6; }
    .test-author {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .test-avatar {
      width: 38px; height: 38px;
      border-radius: 50%;
      background: var(--sky);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 0.9rem;
      color: white;
      flex-shrink: 0;
    }
    .test-name { font-weight: 600; font-size: 0.9rem; }
    .test-role { font-size: 0.8rem; opacity: 0.65; }

    .unique {
      background: var(--light);
      padding: 70px 20px;
      text-align: center;
    }
    .unique h2 {
      font-family: 'Fraunces', serif;
      font-size: clamp(1.6rem, 3.5vw, 2.4rem);
      font-weight: 900;
      margin-bottom: 12px;
    }
    .unique p.lead { color: var(--gray); font-size: 1.05rem; max-width: 600px; margin: 0 auto 48px; }
    .diff-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.95rem;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 4px 20px rgba(0,0,0,0.07);
    }
    .diff-table th {
      padding: 16px 20px;
      font-weight: 700;
      font-size: 0.9rem;
      text-align: left;
    }
    .diff-table th:first-child { background: #F3F4F6; color: var(--navy); }
    .diff-table th:nth-child(2) { background: #FEECEA; color: var(--red-alert); }
    .diff-table th:last-child { background: var(--navy); color: white; }
    .diff-table td {
      padding: 14px 20px;
      text-align: left;
      border-bottom: 1px solid #E5E7EB;
      background: white;
    }
    .diff-table td:nth-child(2) { color: var(--red-alert); background: #FFF5F5; }
    .diff-table td:last-child { color: var(--green); background: #F0FFF4; font-weight: 500; }

    .pricing {
      background: white;
      padding: 70px 20px;
      text-align: center;
    }
    .pricing h2 {
      font-family: 'Fraunces', serif;
      font-size: clamp(1.6rem, 3.5vw, 2.4rem);
      font-weight: 900;
      margin-bottom: 12px;
    }
    .pricing p.lead { color: var(--gray); font-size: 1.05rem; max-width: 520px; margin: 0 auto 48px; }
    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 24px;
      max-width: 900px;
      margin: 0 auto 40px;
    }
    .plan .plan-guia-img-wrap {
      text-align: center;
      margin-bottom: 20px;
    }
    .plan .plan-guia-img {
      width: 100%;
      max-width: 160px;
      height: auto;
      border-radius: 10px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.12);
      display: block;
      margin: 0 auto;
    }
    .plan {
      border: 2px solid #E5E7EB;
      border-radius: 16px;
      padding: 32px 28px;
      text-align: left;
      position: relative;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .plan:hover { transform: translateY(-4px); }
    .plan.featured {
      border-color: var(--blue);
      box-shadow: 0 12px 40px rgba(26,94,168,0.15);
      padding: 36px 32px;
      border-width: 3px;
      background: linear-gradient(180deg, #F0F6FF 0%, white 120px);
    }
    .plan.featured .plan-bonus-img {
      width: 100%;
      max-width: 200px;
      height: auto;
      border-radius: 10px;
      margin: 12px 0 16px;
      box-shadow: 0 6px 20px rgba(0,0,0,0.08);
      display: block;
    }
    .plan.featured .plan-includes {
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--blue);
      margin-bottom: 4px;
    }
    .plan.featured .plan-bonus-list {
      list-style: none;
      margin: 16px 0 24px;
      padding: 0;
    }
    .plan.featured .plan-bonus-list li {
      padding: 10px 0;
      font-size: 0.95rem;
      font-weight: 500;
      color: var(--navy);
      border-bottom: 1px solid rgba(26,94,168,0.12);
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .plan.featured .plan-bonus-list li::before {
      content: '✓';
      color: var(--green);
      font-weight: 700;
      flex-shrink: 0;
    }
    .plan-badge {
      position: absolute;
      top: -14px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--blue);
      color: white;
      font-size: 0.75rem;
      font-weight: 700;
      padding: 4px 16px;
      border-radius: 100px;
      white-space: nowrap;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .plan-name { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--gray); margin-bottom: 8px; }
    .plan-price-old { font-size: 0.9rem; color: var(--gray); text-decoration: line-through; }
    .plan-price {
      font-family: 'Fraunces', serif;
      font-size: 3rem;
      font-weight: 900;
      color: var(--navy);
      line-height: 1;
      margin: 4px 0;
    }
    .plan-price sup { font-size: 1.2rem; vertical-align: super; }
    .plan-price-note { font-size: 0.82rem; color: var(--gray); margin-bottom: 24px; }
    .plan-items { list-style: none; margin-bottom: 28px; }
    .plan-items li {
      padding: 8px 0;
      font-size: 0.9rem;
      border-bottom: 1px solid #F3F4F6;
      display: flex;
      align-items: flex-start;
      gap: 8px;
    }
    .plan-items li .pi { flex-shrink: 0; }
    .plan-items li.bonus { color: var(--blue); font-weight: 500; }
    .plan-items li.miss { color: #9CA3AF; text-decoration: line-through; }
    .plan-warn {
      font-size: 0.82rem;
      color: var(--red-alert);
      margin-bottom: 20px;
      font-weight: 500;
    }
    .plan .cta-btn { width: 100%; text-align: center; display: block; font-size: 1rem; padding: 16px 24px; }
    .plan.featured .cta-btn { background: var(--blue); color: white; box-shadow: 0 6px 20px rgba(26,94,168,0.3); }
    .plan.featured .cta-btn:hover { background: var(--navy); }

    .savings-note {
      background: var(--light);
      border-radius: 12px;
      padding: 20px 28px;
      font-size: 1rem;
      font-weight: 500;
      color: var(--navy);
      max-width: 560px;
      margin: 0 auto 48px;
      border: 1px solid rgba(91,164,212,0.2);
    }
    .savings-note strong { color: var(--blue); font-size: 1.1rem; }

    .guarantee {
      background: var(--mint);
      padding: 60px 20px;
      text-align: center;
    }
    .guarantee-box {
      background: white;
      border-radius: 16px;
      padding: 40px 32px;
      max-width: 620px;
      margin: 0 auto;
      box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    }
    .guarantee-icon { font-size: 3rem; margin-bottom: 16px; }
    .guarantee h2 {
